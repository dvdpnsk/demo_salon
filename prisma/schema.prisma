// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ServiceCategory {
  HAARE
  NAILS
  BROWS
  PFLEGE
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Service {
  id              String          @id @default(cuid())
  name            String
  category        ServiceCategory
  durationMinutes Int
  priceCents      Int
  createdAt       DateTime        @default(now())

  staff    StaffService[]
  bookings Booking[]
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String?
  createdAt DateTime @default(now())

  services     StaffService[]
  workingHours WorkingHours[]
  bookings     Booking[]
}

model StaffService {
  id        String @id @default(cuid())
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
}

model WorkingHours {
  id          String @id @default(cuid())
  staffId     String
  weekday     Int // 0 = Sonntag ... 6 = Samstag
  startMinute Int // Minuten seit Mitternacht, z.B. 540 = 09:00
  endMinute   Int

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, weekday])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String
  createdAt DateTime @default(now())

  bookings Booking[]
}

model Booking {
  id         String        @id @default(cuid())
  customerId String
  staffId    String
  serviceId  String
  startTime  DateTime
  endTime    DateTime
  status     BookingStatus @default(CONFIRMED)
  createdAt  DateTime      @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([staffId, startTime])
}
